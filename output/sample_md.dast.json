                  "content_hash": "df21b43e4998edf6",
                  "node_type": "paragraph",
                  "title": null,
                  "text": "Proration applies to employees who join mid-year. As per Section 3, the\nproration factor is computed monthly.",
                  "level": null,
                  "semantic_path": [
                    "Employee Leave Policy Specification",
                    "Employee Leave Policy Specification",
